{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/maps", "destination": "/api/render?page=maps" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    {
      "source": "/:map(dust2|mirage|inferno|nuke|ancient|anubis|overpass|cache)",
      "destination": "/api/render?page=map&map=:map"
    },
    {
      "source": "/:map(dust2|mirage|inferno|nuke|ancient|anubis|overpass|cache)/:type(smoke|flash|fire|he|decoy)/:slug",
      "destination": "/api/render?page=lineup&map=:map&type=:type&slug=:slug"
    }
  ],
  "functions": {
    "api/render.js": { "includeFiles": "shared/**" },
    "api/sitemap.js": { "includeFiles": "shared/**" }
  }
}
