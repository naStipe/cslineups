{
  "version": 2,
  "builds": [
    { "src": "api/lineups.js", "use": "@vercel/node" },
    { "src": "api/config.js",  "use": "@vercel/node" },
    { "src": "*.html",         "use": "@vercel/static" },
    { "src": "**/*",           "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/lineups", "dest": "/api/lineups.js" },
    { "src": "/api/config",  "dest": "/api/config.js"  },
    { "src": "/(.*)",        "dest": "/$1"             }
  ]
}
